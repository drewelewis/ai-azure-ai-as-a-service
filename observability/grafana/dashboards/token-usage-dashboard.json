{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "datasource",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Token usage monitoring for Azure AI Gateway (APIM)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "grafana-azure-monitor-datasource",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            },
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "azureMonitor": {
            "dimensionFilters": [],
            "metricDefinition": "Microsoft.ApiManagement/service",
            "metricName": "TokensUsed",
            "metricNamespace": "Microsoft.ApiManagement/service",
            "resourceGroup": "$resource_group",
            "resourceName": "$apim_name",
            "timeGrain": "PT5M",
            "aggregation": "Total"
          },
          "datasource": {
            "type": "grafana-azure-monitor-datasource",
            "uid": "${datasource}"
          },
          "queryType": "Azure Monitor",
          "refId": "A"
        }
      ],
      "title": "Token Usage (5-minute intervals)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "grafana-azure-monitor-datasource",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 95
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "orientation": "auto",
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "pluginVersion": "9.5.3",
      "targets": [
        {
          "azureLogAnalytics": {
            "query": "let quotaLimit = 100000;\nApiManagementGatewayLogs\n| where TimeGenerated > ago(1h)\n| summarize TokensUsed = sum(toint(customDimensions['TokensUsed']))\n| extend QuotaUsed = (TokensUsed * 100.0) / quotaLimit\n| project QuotaUsed",
            "resource": "/subscriptions/$subscription_id/resourceGroups/$resource_group/providers/microsoft.insights/components/$app_insights_name"
          },
          "datasource": {
            "type": "grafana-azure-monitor-datasource",
            "uid": "${datasource}"
          },
          "queryType": "Azure Log Analytics",
          "refId": "A"
        }
      ],
      "title": "Quota Usage (Last Hour)",
      "type": "gauge"
    },
    {
      "datasource": {
        "type": "grafana-azure-monitor-datasource",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          },
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": ["value"]
        },
        "pieType": "pie",
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "azureLogAnalytics": {
            "query": "ApiManagementGatewayLogs\n| where TimeGenerated > ago(24h)\n| extend Model = tostring(customDimensions['Model'])\n| summarize Requests = count() by Model\n| order by Requests desc",
            "resource": "/subscriptions/$subscription_id/resourceGroups/$resource_group/providers/microsoft.insights/components/$app_insights_name"
          },
          "datasource": {
            "type": "grafana-azure-monitor-datasource",
            "uid": "${datasource}"
          },
          "queryType": "Azure Log Analytics",
          "refId": "A"
        }
      ],
      "title": "Model Usage Distribution (24h)",
      "type": "piechart"
    },
    {
      "datasource": {
        "type": "grafana-azure-monitor-datasource",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "none",
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            },
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "normal"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "options": {
        "legend": {
          "calcs": ["sum"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "azureLogAnalytics": {
            "query": "ApiManagementGatewayLogs\n| where TimeGenerated > ago(7d)\n| extend LOB = tostring(customDimensions['LineOfBusiness'])\n| summarize TokensUsed = sum(toint(customDimensions['TokensUsed'])) by bin(TimeGenerated, 1d), LOB\n| order by TimeGenerated asc",
            "resource": "/subscriptions/$subscription_id/resourceGroups/$resource_group/providers/microsoft.insights/components/$app_insights_name"
          },
          "datasource": {
            "type": "grafana-azure-monitor-datasource",
            "uid": "${datasource}"
          },
          "queryType": "Azure Log Analytics",
          "refId": "A"
        }
      ],
      "title": "Token Usage by LOB (7 days)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "grafana-azure-monitor-datasource",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Cost (USD)"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              },
              {
                "id": "unit",
                "value": "currencyUSD"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 5,
      "options": {
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": ["sum"],
          "show": true
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Tokens Used"
          }
        ]
      },
      "pluginVersion": "9.5.3",
      "targets": [
        {
          "azureLogAnalytics": {
            "query": "ApiManagementGatewayLogs\n| where TimeGenerated > ago(30d)\n| extend LOB = tostring(customDimensions['LineOfBusiness'])\n| extend Model = tostring(customDimensions['Model'])\n| extend TokensUsed = toint(customDimensions['TokensUsed'])\n| summarize TokensUsed = sum(TokensUsed) by LOB\n| extend CostUSD = TokensUsed * 0.00001\n| project LOB, TokensUsed, CostUSD\n| order by TokensUsed desc",
            "resource": "/subscriptions/$subscription_id/resourceGroups/$resource_group/providers/microsoft.insights/components/$app_insights_name"
          },
          "datasource": {
            "type": "grafana-azure-monitor-datasource",
            "uid": "${datasource}"
          },
          "queryType": "Azure Log Analytics",
          "refId": "A"
        }
      ],
      "title": "Cost by LOB (30 days)",
      "type": "table"
    }
  ],
  "refresh": "30s",
