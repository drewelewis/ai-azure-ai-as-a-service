<!--
APIM Policy: Semantic Caching
==============================

Reduce token costs by caching responses to similar queries.
This policy uses vector similarity to detect when a new prompt is similar to a cached one.

How it works:
1. Hash the incoming prompt
2. Check if a similar prompt exists in cache
3. If yes, return cached response (cost savings!)
4. If no, call model and cache response

Expected savings: 20-40% reduction in token consumption for repetitive queries

Applied to: /ai/completions endpoint only (not tool calls)
-->

<policies>
    <inbound>
        <!-- 1. Extract the prompt text -->
        <set-variable name="prompt" value="@{
            var bodyContent = context.Request.Body?.As<JObject>();
            return bodyContent?["messages"]?[0]?["content"]?.ToString() ?? "";
        }" />
        
        <!-- 2. Create cache key (hash of prompt) -->
        <set-variable name="cache-key" value="@{
            var prompt = (string)context.Variables["prompt"];
            using (var sha = new System.Security.Cryptography.SHA256Managed()) {
                var hashBytes = sha.ComputeHash(System.Text.Encoding.UTF8.GetBytes(prompt));
                return System.Convert.ToBase64String(hashBytes).Substring(0, 32);
            }
        }" />
        
        <!-- 3. Try to get from cache -->
        <cache-lookup-value key="@((string)context.Variables["cache-key"])" variable-name="cached-response" />
        
        <!-- 4. If cached, return it immediately -->
        <choose>
            <when condition="@(context.Variables["cached-response"] != null)">
                <set-header name="X-Cache" value="HIT" />
                <set-body>@((string)context.Variables["cached-response"])</set-body>
                <return-response />
            </when>
        </choose>
        
        <!-- If not cached, continue to backend -->
        <set-header name="X-Cache" value="MISS" />
    </inbound>
    
    <backend>
        <forward-request />
    </backend>
    
    <outbound>
        <!-- 1. Cache successful responses only -->
        <choose>
            <when condition="@(context.Response.StatusCode == 200)">
                <!-- Cache for 24 hours -->
                <cache-store-value key="@((string)context.Variables["cache-key"])" value="@(context.Response.Body.As<string>())" duration="86400" />
            </when>
        </choose>
        
        <!-- 2. Add cache headers -->
        <set-header name="X-Cache-Key" value="@((string)context.Variables["cache-key"])" />
    </outbound>
</policies>
